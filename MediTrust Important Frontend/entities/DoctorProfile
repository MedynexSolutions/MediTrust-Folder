{
  "name": "DoctorProfile",
  "type": "object",
  "properties": {
    "email": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "specialization": {
      "type": "string",
      "enum": [
        "general_physician",
        "cardiologist",
        "dermatologist",
        "neurologist",
        "orthopedic",
        "pediatrician",
        "psychiatrist",
        "gynecologist",
        "ophthalmologist",
        "ent"
      ]
    },
    "qualification": {
      "type": "string"
    },
    "experience_years": {
      "type": "number"
    },
    "license_number": {
      "type": "string"
    },
    "hospital_name": {
      "type": "string"
    },
    "hospital_address": {
      "type": "string"
    },
    "consultation_fees": {
      "type": "object",
      "properties": {
        "offline": {
          "type": "number"
        },
        "chat": {
          "type": "number"
        },
        "audio": {
          "type": "number"
        },
        "video": {
          "type": "number"
        }
      }
    },
    "available_slots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "profile_image": {
      "type": "string"
    },
    "rating": {
      "type": "number"
    },
    "is_verified": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "email",
    "name",
    "specialization"
  ]
}